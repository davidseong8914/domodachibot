#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import RPi.GPIO as GPIO
import time

SERVO = 16

GPIO.setmode(GPIO.BCM)
GPIO.setwarnings(False)
GPIO.setup(SERVO, GPIO.OUT)

pwm = GPIO.PWM(SERVO, 50)  # 50 Hz
pwm.start(0)


def set_angle(angle):
    duty = 2.5 + (angle / 180.0) * 10.0
    pwm.ChangeDutyCycle(duty)
    print("Angle: {} deg  Duty: {:.1f}%".format(angle, duty))
    time.sleep(1)


try:
    set_angle(0)
    set_angle(90)
    set_angle(180)
    set_angle(90)
    set_angle(0)

except KeyboardInterrupt:
    print("\nStopped")

finally:
    pwm.ChangeDutyCycle(0)
    pwm.stop()
    GPIO.cleanup()
    print("Done")
